# Environment variables
DISCORD_TOKEN=your_discord_bot_token_here
XAI_API_KEY=your_xai_api_key_here


# Model Configuration (Optional - defaults shown)
GROK_TEXT_MODEL=grok-4.3
GROK_VISION_MODEL=grok-4.3
GROK_IMAGE_MODEL=grok-imagine-image-quality
# Document model must support agent tools and file analysis
GROK_DOCUMENT_MODEL=grok-4.3


# Timezone Configuration (Optional - defaults to America/Chicago)
# Use IANA timezone names: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# Examples: America/New_York, America/Los_Angeles, Europe/London, Asia/Tokyo
TIMEZONE=America/Chicago

# Search Configuration (Optional - defaults shown)
ENABLE_WEB_SEARCH=true
# Enable X/Twitter search (default: false - requires additional API access)
ENABLE_X_SEARCH=false
# Enable code execution tool (default: false - allows Grok to run Python code)
ENABLE_CODE_EXECUTION=false
# Enable stable conversation/cache hints for lower repeated-context cost
ENABLE_PROMPT_CACHE_HINTS=true
# Reasoning effort for normal chat: none, low, medium, or high.
# The current xAI SDK maps medium/high to high and omits reasoning for none.
GROK_REASONING_EFFORT=low
# Reasoning effort for document, image, and Discord history analysis.
GROK_ANALYSIS_REASONING_EFFORT=high
# Maximum messages to scan for keyword searches (default: 10000)
# Higher values = more thorough search but slower performance
MAX_KEYWORD_SCAN=10000
# Default number of messages to scan when no time period specified (default: 5000)
# Used for both explicit !search commands and natural language queries with time references
# e.g., "who talks about X the most?", "in the past month", "recently"
# Note: Time periods like "past month" don't map to specific counts (varies by server activity)
# Higher values = more history coverage but slower scans
DEFAULT_SEARCH_LIMIT=5000
# Maximum messages to send to Grok for analysis (default: 500)
# Higher values = more context for analysis but higher API costs
# Typical costs: 100 msgs = $0.002-0.005, 500 msgs = $0.01-0.025, 1000 msgs = $0.02-0.05
MAX_MESSAGES_ANALYZED=500
# Enable natural language Discord history analysis (default: true)
# When enabled, Gronk can detect queries like "who talks about X the most?" and automatically search Discord history
ENABLE_NL_HISTORY_SEARCH=true
# Comedy art director: rewrite image-generation prompts to be funnier before
# they reach the image model (default: true). Falls back to the raw prompt on
# any error. Tune the system prompt in image_generation.py.
ENABLE_COMEDY_DIRECTOR=true

# Conversation History Configuration (Optional - defaults shown)
# Path to SQLite database for storing conversation history
# In Docker: Use 'data/conversation_history.db' (persisted via volume mount)
# Local dev: Use 'conversation_history.db' or any path you prefer
CONVERSATION_DB_PATH=data/conversation_history.db
# Path for generated personas and per-channel active persona selections
PERSONA_STORE_PATH=data/personas.json
# Hours to retain conversation history (default: 24)
# Conversations older than this will be automatically deleted
# Set to 0 to disable automatic cleanup (not recommended - unlimited storage)
CONVERSATION_RETENTION_HOURS=24

# Pricing Configuration (Optional - defaults based on current xAI Grok 4.3 pricing)
# Text model pricing (per 1M tokens)
GROK_TEXT_INPUT_COST=1.25
GROK_TEXT_OUTPUT_COST=2.50
GROK_TEXT_CACHED_COST=0.20
# Vision model pricing (per 1M tokens, Grok 4.3 image input)
GROK_VISION_INPUT_COST=1.25
GROK_VISION_OUTPUT_COST=2.50
# Image generation (per generated 1K image; 2K is currently $0.07)
GROK_IMAGE_OUTPUT_COST=0.05
# Server-side tool pricing (per 1,000 invocations) - web_search, x_search, code_execution
GROK_TOOL_COST=5.00
